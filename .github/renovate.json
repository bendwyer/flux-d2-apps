{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "prHourlyLimit": 0,
  "labels": ["dependencies"],
  "rebaseWhen": "behind-base-branch",
  "separateMinorPatch": true,
  "minimumReleaseAge": "24 hours",
  "flux": { "managerFilePatterns": ["/components/.+\\.yaml$/"] },
  "kubernetes": { "managerFilePatterns": ["/components/.+\\.yaml$/"] },
  "github-actions": { "enabled": false },
  "packageRules": [
    {
      "description": "Use semver-coerced versioning for docker images",
      "matchDatasources": ["docker"],
      "versioning": "semver-coerced",
      "pinDigests": true
    },
    {
      "description": "Automerge patch+minor for >=1.x images",
      "matchDatasources": ["docker"],
      "matchCurrentVersion": "/^v?[1-9]/",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Automerge patch only for 0.x images",
      "matchDatasources": ["docker"],
      "matchCurrentVersion": "/^v?0\\./",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true
    },
    {
      "description": "Group comictagger across all manifests",
      "matchPackageNames": ["ghcr.io/bendwyer/containers/comictagger"],
      "groupName": "comictagger"
    },
    {
      "description": "Group ebook-metadata across all manifests",
      "matchPackageNames": ["ghcr.io/bendwyer/containers/ebook-metadata"],
      "groupName": "ebook-metadata"
    },
    {
      "description": "Group kcc across all manifests, never automerge. kcc tags GitHub prereleases (X.Y.0/X.Y.1) before promoting to stable, but Renovate's docker datasource can't see the GitHub prerelease flag (registry artifacts have no prerelease metadata). Manual review per bump to avoid landing on a prerelease.",
      "matchPackageNames": ["ghcr.io/ciromattia/kcc"],
      "groupName": "kcc",
      "automerge": false
    },
    {
      "description": "Kavita: filter out nightly/canary tags; stable releases are bare X.Y.Z[.W]. Use loose versioning to compare 4-segment hotfixes like 0.8.9.1 correctly.",
      "matchPackageNames": ["ghcr.io/kareadita/kavita"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+(\\.\\d+)?$/",
      "versioning": "loose"
    }
  ]
}
